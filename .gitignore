# Ambiente / credenciais
.env

# Logs e arquivos gerados
/storage/logs/*
!/storage/logs/.gitkeep
/storage/uploads/*
!/storage/uploads/.htaccess
/storage/exports/*
!/storage/exports/.gitkeep
/storage/backups/*
!/storage/backups/.gitkeep
/storage/installed.lock
/storage/ratelimit/*
!/storage/ratelimit/.gitkeep

# Artefatos locais de teste (não versionar)
/storage/tmp_cookies*.txt
/storage/*.html

# Sistema operacional / editores
.DS_Store
Thumbs.db
*.log

# Dependencias (caso futuramente use composer)
/vendor/

# Artefatos locais de deploy (nao versionar)
/deploy/
/tmp_etapa13_spec.txt
