# =====================================================================
# Exemplo de configuracao de ambiente.
# Copie este arquivo para ".env" e preencha com seus dados reais.
# Em hospedagem Hostinger, o .env fica fora da pasta public (protegido).
# =====================================================================

APP_NAME="Dança Carajás Captação"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://captacao.seudominio.com
APP_TIMEZONE=America/Belem
APP_LOCALE=pt_BR
# Gere com: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=

# Sessao
SESSION_NAME=DCC_SESSION
SESSION_LIFETIME=7200
SESSION_SECURE=true
SESSION_SAMESITE=Lax
SESSION_REGENERATE=900

# Banco de dados (Hostinger: use o prefixo do seu usuario, ex.: u123456789_)
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u000000000_captacao
DB_USERNAME=u000000000_user
DB_PASSWORD=

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# E-mail (configurado em etapa futura)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=no-reply@seudominio.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@seudominio.com
MAIL_FROM_NAME="Dança Carajás Captação"

# Endpoint público de leads (WordPress → CRM)
LEAD_ENDPOINT_ENABLED=true
LEAD_ENDPOINT_SECRET=trocar-por-token-forte
LEAD_RATE_LIMIT_MINUTES=10
LEAD_RATE_LIMIT_MAX_ATTEMPTS=5
