# =====================================================================
# database/.htaccess
# Bloqueia totalmente o acesso web direto a esta pasta.
# Nenhum arquivo .sql (ou qualquer outro) pode ser baixado pelo navegador.
# =====================================================================

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2
<IfModule !mod_authz_core.c>
    Order Allow,Deny
    Deny from all
</IfModule>

# Reforco explicito: bloqueia o download de dumps/scripts SQL e afins
<FilesMatch "\.(sql|sqlite|db|dump|bak|gz|zip)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

Options -Indexes
